# PhD Terminal - Environment Variables Template
# Bu dosyayi .env olarak kopyala ve kendi bilgilerini gir.

# Supabase Bilgileri (Supabase Dashboard > Project Settings > API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Backend API URL (Yerelde calisirken degistirmene gerek yok)
# Canliya (Railway/Render) gectiginde oradaki URL'yi buraya yazarsin.
VITE_API_URL=http://localhost:8000
